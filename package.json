{
  "name": "harmony-health-lms",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:quick": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build:quick && firebase deploy --only hosting",
    "deploy:all": "npm run build:quick && firebase deploy",
    "deploy:functions": "firebase deploy --only functions",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:rules": "jest --config jest.rules.config.cjs",
    "seed": "npx tsx --tsconfig scripts/seed/tsconfig.json scripts/seed/seedAll.ts",
    "seed:users": "npx tsx --tsconfig scripts/seed/tsconfig.json scripts/seed/seedUsers.ts",
    "seed:course": "npx tsx --tsconfig scripts/seed/tsconfig.json scripts/seed/seedCourse.ts",
    "unseed": "npx tsx --tsconfig scripts/seed/tsconfig.json scripts/seed/unseed.ts",
    "unseed:full": "npx tsx --tsconfig scripts/seed/tsconfig.json scripts/seed/unseed.ts --full",
    "reseed": "npm run unseed:full && npm run seed",
    "cleanup:deploy": "npx tsx --tsconfig scripts/seed/tsconfig.json scripts/seed/deploymentCleanup.ts"
  },
  "dependencies": {
    "@tiptap/extension-highlight": "^3.20.5",
    "@tiptap/extension-link": "^3.20.5",
    "@tiptap/extension-placeholder": "^3.20.5",
    "@tiptap/extension-typography": "^3.20.5",
    "@tiptap/extension-underline": "^3.20.5",
    "@tiptap/pm": "^3.20.5",
    "@tiptap/react": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "firebase": "^12.8.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "snd-lib": "^1.2.4",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.11",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "firebase-admin": "^13.6.1",
    "jest": "^30.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
