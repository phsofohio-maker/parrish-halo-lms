VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Production URL for invite links (overrides window.location.origin)
VITE_APP_URL=https://harmony-lms.web.app

# Set to 'true' to connect to Firebase emulators in dev mode
VITE_USE_EMULATORS=false
